UserInputService.InputBegan:Connect(function(i) if bnd and i.UserInputType==Enum.UserInputType.Keyboard then Library.Flags[f]=i.KeyCode.Name;Library:Update(f);bnd=false elseif not bnd and i.KeyCode.Name==Library.Flags[f] then if cb then cb() end end end)
