function e:CreateDropdown(txt,f,ls,cb)
Library.Flags[f]=ls[1];local ih=35
local dp=Instance.new("Frame");dp.Size=UDim2.new(1,-10,0,45);dp.ClipsDescendants=true;applyGlassEffect(dp,6,0.5,0.7);dp.Parent=p
local bt=Instance.new("TextButton");bt.Size=UDim2.new(1,0,0,45);bt.Text=" "..txt.." : "..Library.Flags[f];bt.Font=Enum.Font.Gotham;bt.TextColor3=Library.Theme.Text;bt.TextSize=14;bt.BackgroundTransparency=1;bt.TextXAlignment=Enum.TextXAlignment.Left;bt.Parent=dp
local ct=Instance.new("Frame");ct.Size=UDim2.new(1,0,0,#ls*ih);ct.Position=UDim2.new(0,0,0,45);ct.BackgroundTransparency=1;ct.Parent=dp;Instance.new("UIListLayout",ct)
Library.Elements[f]={Type="Dropdown",Button=bt,Title=txt};local op=false
bt.MouseButton1Click:Connect(function() op=not op;dp.Size=op and UDim2.new(1,-10,0,45+(#ls*ih)) or UDim2.new(1,-10,0,45);p.CanvasSize=UDim2.new(0,0,0,pl.AbsoluteContentSize.Y+20) end)
for _,v in pairs(ls) do local it=Instance.new("TextButton");it.Size=UDim2.new(1,0,0,ih);it.Text=v;it.Font=Enum.Font.Gotham;it.TextColor3=Color3.fromRGB(180,180,180);it.BackgroundTransparency=1;it.Parent=ct;it.MouseButton1Click:Connect(function() Library.Flags[f]=v;Library:Update(f);op=false;dp.Size=UDim2.new(1,-10,0,45);if cb then cb(v) end end) end
end
