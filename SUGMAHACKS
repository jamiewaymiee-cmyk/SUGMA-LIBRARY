end
local no=Instance.new("Frame");no.Size=UDim2.new(1,0,0,80);no.ClipsDescendants=true;applyGlassEffect(no,8,0.2,0.7);no.Parent=self.Notifications
local tl=Instance.new("TextLabel");tl.Size=UDim2.new(1,-10,0,25);tl.Position=UDim2.new(0,10,0,5);tl.Text=t;tl.Font=Enum.Font.GothamBold;tl.TextColor3=Library.Theme.Accent;tl.TextSize=14;tl.TextXAlignment=Enum.TextXAlignment.Left;tl.BackgroundTransparency=1;tl.Parent=no
local bl=Instance.new("TextLabel");bl.Size=UDim2.new(1,-20,0,45);bl.Position=UDim2.new(0,10,0,25);bl.Text=c;bl.Font=Enum.Font.Gotham;bl.TextColor3=Library.Theme.Text;bl.TextSize=13;bl.TextWrapped=true;bl.TextXAlignment=Enum.TextXAlignment.Left;bl.BackgroundTransparency=1;bl.Parent=no
task.delay(d or 5,function() TweenService:Create(no,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play();TweenService:Create(tl,TweenInfo.new(0.5),{TextTransparency=1}):Play();TweenService:Create(bl,TweenInfo.new(0.5),{TextTransparency=1}):Play();task.wait(0.5);no:Destroy() end)
end
function Library:CreateWindow(t)
local sg=Instance.new("ScreenGui");sg.Name="LiquidUI";sg.DisplayOrder=50000;sg.ResetOnSpawn=false;sg.Parent=player:WaitForChild("PlayerGui");self.ScreenGui=sg
