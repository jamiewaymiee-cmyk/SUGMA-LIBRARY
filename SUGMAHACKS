function e:CreateTextBox(txt,f,df,cb)
Library.Flags[f]=df or ""
local bf=Instance.new("Frame");bf.Size=UDim2.new(1,-10,0,45);applyGlassEffect(bf,6,0.5,0.7);bf.Parent=p
local bx=Instance.new("TextBox");bx.Size=UDim2.new(1,-20,1,0);bx.Position=UDim2.new(0,10,0,0);bx.BackgroundTransparency=1;bx.Text=Library.Flags[f];bx.PlaceholderText=txt;bx.Font=Enum.Font.Gotham;bx.TextColor3=Library.Theme.Text;bx.TextSize=14;bx.TextXAlignment=Enum.TextXAlignment.Left;bx.Parent=bf
