local function mv() local pct=math.clamp((UserInputService:GetMouseLocation().X-sb.AbsolutePosition.X)/sb.AbsoluteSize.X,0,1);local val=math.floor((mn+(mx-mn)*pct)*100)/100;Library.Flags[f]=val;sfi.Size=UDim2.new(pct,0,1,0);vl.Text=tostring(val);if cb then cb(val) end end
sf.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then local mc;mc=UserInputService.InputChanged:Connect(function(ic) if ic.UserInputType==Enum.UserInputType.MouseMovement then mv() end end);mv();UserInputService.InputEnded:Connect(function(ie) if ie.UserInputType==Enum.UserInputType.MouseButton1 and mc then mc:Disconnect();mc=nil end end) end end)
