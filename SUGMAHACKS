end
function w:CreateConfigTab()
local t=self:CreateTab("Settings")
t:CreateTextBox("Config Name...","ConfigName","DefaultConfig")
t:CreateButton("Save Config",function() if writefile then local n=Library.Flags["ConfigName"]..".json";writefile(n,HttpService:JSONEncode(Library.Flags));Library:Notify("Config","Saved to "..n,3) else Library:Notify("Error","Your executor does not support writefile.",3) end end)
t:CreateButton("Load Config",function() local n=Library.Flags["ConfigName"]..".json";if isfile and isfile(n) then local s,r=pcall(function() return HttpService:JSONDecode(readfile(n)) end);if s and type(r)=="table" then for k,v in pairs(r) do Library.Flags[k]=v end;Library:Update();Library:Notify("Config","Successfully loaded "..n,3) else Library:Notify("Error","Failed to parse config file.",3) end else Library:Notify("Error","File not found!",3) end end)
t:CreateButton("Destroy UI",function() Library.ScreenGui:Destroy();if Library.Notifications then Library.Notifications.Parent:Destroy() end end)
end
return w
end
