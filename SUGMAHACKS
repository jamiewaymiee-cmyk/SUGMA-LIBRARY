local function applyGlassEffect(g,r,t,st)
g.BackgroundColor3=Library.Theme.Background;g.BackgroundTransparency=t or 0.4;g.BorderSizePixel=0
local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,r or 8);c.Parent=g
