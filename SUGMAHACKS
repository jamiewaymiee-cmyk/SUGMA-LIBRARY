end
function e:CreateToggle(txt,f,df,cb)
Library.Flags[f]=df or false
local tg=Instance.new("TextButton");tg.Size=UDim2.new(1,-10,0,45);tg.Text=" "..txt;tg.Font=Enum.Font.Gotham;tg.TextColor3=Library.Theme.Text;tg.TextSize=14;tg.TextXAlignment=Enum.TextXAlignment.Left;applyGlassEffect(tg,6,0.5,0.7);tg.Parent=p
local ind=Instance.new("Frame");ind.Size=UDim2.new(0,24,0,24);ind.Position=UDim2.new(1,-34,0.5,-12);applyGlassEffect(ind,4,0.2,0.5);ind.BackgroundColor3=Library.Flags[f] and Library.Theme.Accent or Library.Theme.Secondary;ind.Parent=tg
