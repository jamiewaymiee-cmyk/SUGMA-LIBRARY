function e:CreateKeybind(txt,f,df,cb)
Library.Flags[f]=df.Name;local bnd=false
local bd=Instance.new("TextButton");bd.Size=UDim2.new(1,-10,0,45);bd.Text=" "..txt;bd.Font=Enum.Font.Gotham;bd.TextColor3=Library.Theme.Text;bd.TextSize=14;bd.TextXAlignment=Enum.TextXAlignment.Left;applyGlassEffect(bd,6,0.5,0.7);bd.Parent=p
local lb=Instance.new("TextLabel");lb.Size=UDim2.new(0,80,0,26);lb.Position=UDim2.new(1,-90,0.5,-13);lb.Text=Library.Flags[f];lb.Font=Enum.Font.GothamBold;lb.TextColor3=Library.Theme.Accent;applyGlassEffect(lb,4,0.3,0.5);lb.Parent=bd
