end
function Library:Update(tf)
local function ref(f)
local d=self.Elements[f]
if not d then return end
if d.Type=="Toggle" then d.Indicator.BackgroundColor3=self.Flags[f] and self.Theme.Accent or self.Theme.Secondary
elseif d.Type=="Dropdown" then d.Button.Text=" "..d.Title.." : "..tostring(self.Flags[f])
elseif d.Type=="Keybind" then d.Label.Text=tostring(self.Flags[f])
elseif d.Type=="TextBox" then d.Box.Text=tostring(self.Flags[f])
elseif d.Type=="Slider" then local p=math.clamp((self.Flags[f]-d.Min)/(d.Max-d.Min),0,1);d.Fill.Size=UDim2.new(p,0,1,0);d.ValLabel.Text=tostring(self.Flags[f]) end
end
if tf then ref(tf) else for f,_ in pairs(self.Elements) do ref(f) end end
end
