local Library = {
    Flags = {},
    Elements = {},
    Theme = {
        Accent = Color3.fromRGB(80, 120, 255),
        Background = Color3.fromRGB(15, 15, 20),
        Text = Color3.fromRGB(255, 255, 255),
        Secondary = Color3.fromRGB(45, 45, 50)
    },
    ToggleKey = Enum.KeyCode.RightShift,
    Opened = true,
    Notifications = nil
}

local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local function round(n, b) b = b or 1 return math.floor(n/b + 0.5) * b end

local function applyGlassEffect(g, r, t, s)
    g.BackgroundColor3 = Library.Theme.Background
    g.BackgroundTransparency = t or 0.4
    g.BorderSizePixel = 0
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = g
    if s then
        local st = Instance.new("UIStroke")
        st.Color = Color3.fromRGB(255, 255, 255)
        st.Transparency = s
        st.Thickness = 1
        st.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        st.Parent = g
    end
end

function Library:Update(f)
    local function r(fl)
        local d = self.Elements[fl]
        if not d then return end
        if d.Type == "Toggle" then
            d.Indicator.BackgroundColor3 = self.Flags[fl] and self.Theme.Accent or self.Theme.Secondary
        elseif d.Type == "Dropdown" then
            d.Button.Text = "    " .. d.Title .. " : " .. tostring(self.Flags[fl])
        elseif d.Type == "Keybind" then
            d.Label.Text = tostring(self.Flags[fl])
        elseif d.Type == "TextBox" then
            d.Box.Text = tostring(self.Flags[fl])
        elseif d.Type == "Slider" then
            local p = math.clamp((self.Flags[fl] - d.Min) / (d.Max - d.Min), 0, 1)
            d.Fill.Size = UDim2.new(p, 0, 1, 0)
            d.ValLabel.Text = tostring(self.Flags[fl])
        end
    end
    if f then r(f) else for k, _ in pairs(self.Elements) do r(k) end end
end

function Library:Notify(t, c, d)
    if not self.Notifications then
        local ng = Instance.new("ScreenGui")
        ng.Name = "LiquidNotifs"
        ng.DisplayOrder = 50000
        ng.Parent = player:WaitForChild("PlayerGui")
        local h = Instance.new("Frame")
        h.Size = UDim2.new(0, 300, 1, -20)
        h.Position = UDim2.new(1, -310, 0, 10)
        h.BackgroundTransparency = 1
        h.Parent = ng
        local l = Instance.new("UIListLayout")
        l.VerticalAlignment = Enum.VerticalAlignment.Bottom
        l.Padding = UDim.new(0, 10)
        l.Parent = h
        self.Notifications = h
    end
    local nf = Instance.new("Frame")
    nf.Size = UDim2.new(1, 0, 0, 80)
    nf.ClipsDescendants = true
    applyGlassEffect(nf, 8, 0.2, 0.7)
    nf.Parent = self.Notifications
    local tl = Instance.new("TextLabel")
    tl.Size = UDim2.new(1, -10, 0, 25)
    tl.Position = UDim2.new(0, 10, 0, 5)
    tl.Text = t
    tl.Font = Enum.Font.GothamBold
    tl.TextColor3 = Library.Theme.Accent
    tl.TextSize = 14
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.BackgroundTransparency = 1
    tl.Parent = nf
    local bl = Instance.new("TextLabel")
    bl.Size = UDim2.new(1, -20, 0, 45)
    bl.Position = UDim2.new(0, 10, 0, 25)
    bl.Text = c
    bl.Font = Enum.Font.Gotham
    bl.TextColor3 = Library.Theme.Text
    bl.TextSize = 13
    bl.TextWrapped = true
    bl.TextXAlignment = Enum.TextXAlignment.Left
    bl.BackgroundTransparency = 1
    bl.Parent = nf
    task.delay(d or 5, function()
        TweenService:Create(nf, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        TweenService:Create(tl, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        TweenService:Create(bl, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        task.wait(0.5) nf:Destroy()
    end)
end

function Library:CreateWindow(t)
    local sg = Instance.new("ScreenGui")
    sg.Name = "LiquidUI"
    sg.DisplayOrder = 50000
    sg.ResetOnSpawn = false
    sg.Parent = player:WaitForChild("PlayerGui")
    self.ScreenGui = sg

    UserInputService.InputBegan:Connect(function(i, g)
        if not g and i.KeyCode == self.ToggleKey then
            self.Opened = not self.Opened
            sg.Enabled = self.Opened
        end
    end)

    local m = Instance.new("Frame")
    m.Size = UDim2.new(0, 650, 0, 500)
    m.Position = UDim2.new(0.5, -325, 0.5, -250)
    applyGlassEffect(m, 12, 0.2, 0.6)
    m.Parent = sg

    local dr, ds, sp
    m.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            local obj = sg:GetGuiObjectsAtPosition(i.Position.X, i.Position.Y)[1]
            if obj == m or obj.Parent == m then
                dr = true ds = i.Position sp = m.Position
            end
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement and dr then
            local d = i.Position - ds
            m.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dr = false end end)

    local tb = Instance.new("Frame")
    tb.Size = UDim2.new(1, 0, 0, 45)
    applyGlassEffect(tb, 12, 0.4, nil)
    tb.Parent = m

    local tl = Instance.new("TextLabel")
    tl.Text = "  " .. (t or "Liquid Library")
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.BackgroundTransparency = 1
    tl.TextColor3 = Library.Theme.Text
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 18
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.Parent = tb

    local ts = Instance.new("ScrollingFrame")
    ts.Size = UDim2.new(0, 150, 1, -55)
    ts.Position = UDim2.new(0, 8, 0, 50)
    ts.BackgroundTransparency = 1
    ts.ScrollBarThickness = 0
    ts.Parent = m
    Instance.new("UIListLayout", ts).Padding = UDim.new(0, 5)

    local pc = Instance.new("Frame")
    pc.Size = UDim2.new(1, -175, 1, -55)
    pc.Position = UDim2.new(0, 165, 0, 50)
    pc.BackgroundTransparency = 1
    pc.Parent = m

    local w = { CurrentTab = nil }

    function w:CreateTab(n)
        local tbt = Instance.new("TextButton")
        tbt.Size = UDim2.new(1, -5, 0, 40)
        tbt.Text = n
        tbt.TextColor3 = Library.Theme.Text
        tbt.Font = Enum.Font.GothamSemibold
        tbt.TextSize = 14
        applyGlassEffect(tbt, 6, 0.6, 0.8)
        tbt.Parent = ts

        local p = Instance.new("ScrollingFrame")
        p.Size = UDim2.new(1, 0, 1, 0)
        p.Visible = false
        p.BackgroundTransparency = 1
        p.ScrollBarThickness = 2
        p.ScrollBarImageColor3 = Library.Theme.Accent
        p.Parent = pc

        local pl = Instance.new("UIListLayout")
        pl.Padding = UDim.new(0, 8)
        pl.HorizontalAlignment = Enum.HorizontalAlignment.Center
        pl.Parent = p
        
        pl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            p.CanvasSize = UDim2.new(0, 0, 0, pl.AbsoluteContentSize.Y + 20)
        end)

        tbt.MouseButton1Click:Connect(function()
            for _, v in pairs(pc:GetChildren()) do v.Visible = false end
            for _, b in pairs(ts:GetChildren()) do if b:IsA("TextButton") then b.BackgroundColor3 = Library.Theme.Background end end
            p.Visible = true tbt.BackgroundColor3 = Library.Theme.Accent
        end)

        if not w.CurrentTab then p.Visible = true tbt.BackgroundColor3 = Library.Theme.Accent w.CurrentTab = n end

        local el = {}

        function el:CreateLabel(txt)
            local l = Instance.new("TextLabel")
            l.Size = UDim2.new(1, -10, 0, 30)
            l.BackgroundTransparency = 1
            l.Text = "    " .. txt
            l.Font = Enum.Font.GothamSemibold
            l.TextColor3 = Library.Theme.Text
            l.TextSize = 14
            l.TextXAlignment = Enum.TextXAlignment.Left
            l.Parent = p
            return {Set = function(s, nt) l.Text = "    " .. nt end}
        end

        function el:CreateButton(txt, cb)
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -10, 0, 45)
            b.Text = txt
            b.Font = Enum.Font.Gotham
            b.TextColor3 = Library.Theme.Text
            b.TextSize = 14
            applyGlassEffect(b, 6, 0.5, 0.7)
            b.Parent = p
            b.MouseButton1Click:Connect(cb)
        end

        function el:CreateSlider(txt, fl, min, max, d, st, cb)
            local stp = st or 1
            Library.Flags[fl] = d or min
            local sf = Instance.new("Frame")
            sf.Size = UDim2.new(1, -10, 0, 55)
            applyGlassEffect(sf, 6, 0.5, 0.7)
            sf.Parent = p
            local ti = Instance.new("TextLabel")
            ti.Size = UDim2.new(1, -20, 0, 25)
            ti.Position = UDim2.new(0, 10, 0, 5)
            ti.BackgroundTransparency = 1
            ti.Text = txt
            ti.Font = Enum.Font.Gotham
            ti.TextColor3 = Library.Theme.Text
            ti.TextSize = 14
            ti.TextXAlignment = Enum.TextXAlignment.Left
            ti.Parent = sf
            local vl = Instance.new("TextLabel")
            vl.Size = UDim2.new(0, 60, 0, 25)
            vl.Position = UDim2.new(1, -70, 0, 5)
            vl.BackgroundTransparency = 1
            vl.Text = tostring(Library.Flags[fl])
            vl.Font = Enum.Font.GothamBold
            vl.TextColor3 = Library.Theme.Accent
            vl.TextSize = 14
            vl.TextXAlignment = Enum.TextXAlignment.Right
            vl.Parent = sf
            local sb = Instance.new("Frame")
            sb.Size = UDim2.new(1, -20, 0, 6)
            sb.Position = UDim2.new(0, 10, 0, 38)
            sb.BackgroundColor3 = Library.Theme.Secondary
            sb.BorderSizePixel = 0
            sb.Parent = sf
            Instance.new("UICorner", sb).CornerRadius = UDim.new(0, 4)
            local sfl = Instance.new("Frame")
            sfl.Size = UDim2.new((Library.Flags[fl] - min) / (max - min), 0, 1, 0)
            sfl.BackgroundColor3 = Library.Theme.Accent
            sfl.BorderSizePixel = 0
            sfl.Parent = sb
            Instance.new("UICorner", sfl).CornerRadius = UDim.new(0, 4)
            Library.Elements[fl] = {Type = "Slider", Fill = sfl, ValLabel = vl, Min = min, Max = max}
            local function move()
                local mX = UserInputService:GetMouseLocation().X
                local aX = sb.AbsolutePosition.X
                local aW = sb.AbsoluteSize.X
                local per = math.clamp((mX - aX) / aW, 0, 1)
                local val = round(min + (max - min) * per, stp)
                Library.Flags[fl] = val
                sfl.Size = UDim2.new(math.clamp((val - min) / (max - min), 0, 1), 0, 1, 0)
                vl.Text = tostring(val)
                if cb then cb(val) end
            end
            sf.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dr = false
                    local con
                    con = UserInputService.InputChanged:Connect(function(io) if io.UserInputType == Enum.UserInputType.MouseMovement then move() end end)
                    move()
                    local endCon
                    endCon = UserInputService.InputEnded:Connect(function(io)
                        if io.UserInputType == Enum.UserInputType.MouseButton1 then con:Disconnect() endCon:Disconnect() end
                    end)
                end
            end)
        end

        function el:CreateTextBox(txt, fl, d, cb)
            Library.Flags[fl] = d or ""
            local bf = Instance.new("Frame")
            bf.Size = UDim2.new(1, -10, 0, 45)
            applyGlassEffect(bf, 6, 0.5, 0.7)
            bf.Parent = p
            local box = Instance.new("TextBox")
            box.Size = UDim2.new(1, -20, 1, 0)
            box.Position = UDim2.new(0, 10, 0, 0)
            box.BackgroundTransparency = 1
            box.Text = Library.Flags[fl]
            box.PlaceholderText = txt
            box.Font = Enum.Font.Gotham
            box.TextColor3 = Library.Theme.Text
            box.TextSize = 14
            box.TextXAlignment = Enum.TextXAlignment.Left
            box.Parent = bf
            Library.Elements[fl] = {Type = "TextBox", Box = box}
            box.FocusLost:Connect(function() Library.Flags[fl] = box.Text if cb then cb(box.Text) end end)
        end

        function el:CreateToggle(txt, fl, d, cb)
            Library.Flags[fl] = d or false
            local t = Instance.new("TextButton")
            t.Size = UDim2.new(1, -10, 0, 45)
            t.Text = "   " .. txt
            t.Font = Enum.Font.Gotham
            t.TextColor3 = Library.Theme.Text
            t.TextSize = 14
            t.TextXAlignment = Enum.TextXAlignment.Left
            applyGlassEffect(t, 6, 0.5, 0.7)
            t.Parent = p
            local ind = Instance.new("Frame")
            ind.Size = UDim2.new(0, 24, 0, 24)
            ind.Position = UDim2.new(1, -34, 0.5, -12)
            applyGlassEffect(ind, 4, 0.2, 0.5)
            ind.BackgroundColor3 = Library.Flags[fl] and Library.Theme.Accent or Library.Theme.Secondary
            ind.Parent = t
            Library.Elements[fl] = {Type = "Toggle", Indicator = ind}
            t.MouseButton1Click:Connect(function() Library.Flags[fl] = not Library.Flags[fl] Library:Update(fl) if cb then cb(Library.Flags[fl]) end end)
        end

        function el:CreateKeybind(txt, fl, d, cb)
            Library.Flags[fl] = d.Name
            local bnd = false
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -10, 0, 45)
            b.Text = "   " .. txt
            b.Font = Enum.Font.Gotham
            b.TextColor3 = Library.Theme.Text
            b.TextSize = 14
            b.TextXAlignment = Enum.TextXAlignment.Left
            applyGlassEffect(b, 6, 0.5, 0.7)
            b.Parent = p
            local lb = Instance.new("TextLabel")
            lb.Size = UDim2.new(0, 80, 0, 26)
            lb.Position = UDim2.new(1, -90, 0.5, -13)
            lb.Text = Library.Flags[fl]
            lb.Font = Enum.Font.GothamBold
            lb.TextColor3 = Library.Theme.Accent
            applyGlassEffect(lb, 4, 0.3, 0.5)
            lb.Parent = b
            Library.Elements[fl] = {Type = "Keybind", Label = lb}
            b.MouseButton1Click:Connect(function() bnd = true lb.Text = "..." end)
            UserInputService.InputBegan:Connect(function(i)
                if bnd and i.UserInputType == Enum.UserInputType.Keyboard then
                    Library.Flags[fl] = i.KeyCode.Name Library:Update(fl) bnd = false
                elseif not bnd and i.KeyCode.Name == Library.Flags[fl] then
                    if cb then cb() end
                end
            end)
        end

        function el:CreateDropdown(txt, fl, l, cb)
            Library.Flags[fl] = l[1]
            local ih = 35
            local d = Instance.new("Frame")
            d.Size = UDim2.new(1, -10, 0, 45)
            d.ClipsDescendants = true
            applyGlassEffect(d, 6, 0.5, 0.7)
            d.Parent = p
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, 0, 0, 45)
            b.Text = "   " .. txt .. " : " .. Library.Flags[fl]
            b.Font = Enum.Font.Gotham
            b.TextColor3 = Library.Theme.Text
            b.TextSize = 14
            b.BackgroundTransparency = 1
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.Parent = d
            local c = Instance.new("Frame")
            c.Size = UDim2.new(1, 0, 0, #l * ih)
            c.Position = UDim2.new(0, 0, 0, 45)
            c.BackgroundTransparency = 1
            c.Parent = d
            Instance.new("UIListLayout", c)
            Library.Elements[fl] = {Type = "Dropdown", Button = b, Title = txt}
            local o = false
            b.MouseButton1Click:Connect(function()
                o = not o d.Size = o and UDim2.new(1, -10, 0, 45 + (#l * ih)) or UDim2.new(1, -10, 0, 45)
                p.CanvasSize = UDim2.new(0, 0, 0, pl.AbsoluteContentSize.Y + 20)
            end)
            for _, v in pairs(l) do
                local it = Instance.new("TextButton")
                it.Size = UDim2.new(1, 0, 0, ih)
                it.Text = v
                it.Font = Enum.Font.Gotham
                it.TextColor3 = Color3.fromRGB(180, 180, 180)
                it.BackgroundTransparency = 1
                it.Parent = c
                it.MouseButton1Click:Connect(function()
                    Library.Flags[fl] = v Library:Update(fl) o = false d.Size = UDim2.new(1, -10, 0, 45)
                    if cb then cb(v) end
                end)
            end
        end
        return el
    end

    function w:CreateConfigTab()
        local t = self:CreateTab("Settings")
        t:CreateTextBox("Config Name...", "ConfigName", "DefaultConfig")
        t:CreateButton("Save Config", function()
            if writefile then
                local n = Library.Flags["ConfigName"] .. ".json"
                writefile(n, HttpService:JSONEncode(Library.Flags))
                Library:Notify("Config", "Saved to " .. n, 3)
            end
        end)
        t:CreateButton("Load Config", function()
            local n = Library.Flags["ConfigName"] .. ".json"
            if isfile and isfile(n) then
                local s, res = pcall(function() return HttpService:JSONDecode(readfile(n)) end)
                if s then for k, v in pairs(res) do Library.Flags[k] = v end Library:Update() end
            end
        end)
        t:CreateButton("Destroy UI", function() sg:Destroy() if Library.Notifications then Library.Notifications.Parent:Destroy() end end)
    end
    return w
end

return Library
