local tb=Instance.new("Frame");tb.Size=UDim2.new(1,0,0,45);applyGlassEffect(tb,12,0.4,nil);tb.Parent=m
local tt=Instance.new("TextLabel");tt.Text=" "..(t or "Liquid Library");tt.Size=UDim2.new(1,0,1,0);tt.BackgroundTransparency=1;tt.TextColor3=Library.Theme.Text;tt.Font=Enum.Font.GothamBold;tt.TextSize=18;tt.TextXAlignment=Enum.TextXAlignment.Left;tt.Parent=tb
local ts=Instance.new("ScrollingFrame");ts.Size=UDim2.new(0,150,1,-55);ts.Position=UDim2.new(0,8,0,50);ts.BackgroundTransparency=1;ts.ScrollBarThickness=0;ts.Parent=m;Instance.new("UIListLayout",ts).Padding=UDim.new(0,5)
