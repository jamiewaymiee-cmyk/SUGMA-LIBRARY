local n=Instance.new("ScreenGui");n.Name="LiquidNotifications";n.DisplayOrder=50000;n.Parent=player:WaitForChild("PlayerGui")
local h=Instance.new("Frame");h.Size=UDim2.new(0,300,1,-20);h.Position=UDim2.new(1,-310,0,10);h.BackgroundTransparency=1;h.Parent=n
