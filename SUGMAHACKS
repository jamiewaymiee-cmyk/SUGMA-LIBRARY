function e:CreateSlider(txt,f,mn,mx,df,cb)
Library.Flags[f]=df or mn
local sf=Instance.new("Frame");sf.Size=UDim2.new(1,-10,0,55);applyGlassEffect(sf,6,0.5,0.7);sf.Parent=p
local tl=Instance.new("TextLabel");tl.Size=UDim2.new(1,-20,0,25);tl.Position=UDim2.new(0,10,0,5);tl.BackgroundTransparency=1;tl.Text=txt;tl.Font=Enum.Font.Gotham;tl.TextColor3=Library.Theme.Text;tl.TextSize=14;tl.TextXAlignment=Enum.TextXAlignment.Left;tl.Parent=sf
local vl=Instance.new("TextLabel");vl.Size=UDim2.new(0,40,0,25);vl.Position=UDim2.new(1,-50,0,5);vl.BackgroundTransparency=1;vl.Text=tostring(Library.Flags[f]);vl.Font=Enum.Font.GothamBold;vl.TextColor3=Library.Theme.Accent;vl.TextSize=14;vl.TextXAlignment=Enum.TextXAlignment.Right;vl.Parent=sf
local sb=Instance.new("Frame");sb.Size=UDim2.new(1,-20,0,6);sb.Position=UDim2.new(0,10,0,38);sb.BackgroundColor3=Library.Theme.Secondary;sb.BorderSizePixel=0;sb.Parent=sf;Instance.new("UICorner",sb).CornerRadius=UDim.new(0,4)
